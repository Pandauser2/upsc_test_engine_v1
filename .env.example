# Database: use SQLite for quick local testing (no Docker). Use PostgreSQL for production.
# SQLite (default for testing):
DATABASE_URL=sqlite:///./upsc_dev.db
# PostgreSQL (run: docker-compose up -d):
# DATABASE_URL=postgresql://user:password@localhost:5432/upsc_test_engine

# JWT (Step 3)
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# LLM (Step 6) - required for generating questions
# Options: claude | openai | gemini
LLM_PROVIDER=gemini
# Gemini (Google AI Studio): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Or use OpenAI:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# Optional: custom endpoint (e.g. if behind proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Or Claude (default in code if unset):
# LLM_PROVIDER=claude
# CLAUDE_API_KEY=
PROMPT_VERSION=mcq_v1
MAX_GENERATION_TIME_SECONDS=300
MIN_EXTRACTION_WORDS=500
# Optional MCQ pipeline tuning:
# MAX_CONTEXT_CHUNKS=15
# BATCH_VALIDATION_MAX=20
# MCQ fake-progress timer (seconds per question while generation is running):
# MCQ_ESTIMATED_SECONDS_PER_QUESTION=8

# App (MVP: max 100 pages per PDF; reject larger at upload)
UPLOAD_DIR=./uploads
MAX_PDF_PAGES=100
# Extraction runtime tuning (recommended for low-memory instances)
# MAX_OCR_WORKERS=1
# OCR_DPI=300
# OCR_DPI_IMAGE_HEAVY=350
# EXTRACTION_PROGRESS_UPDATE_EVERY_PAGES=5
# Startup sweeper: mark stale processing docs as extraction_failed
# EXTRACTION_STALE_PROCESSING_SECONDS=1200
# Optional: local cached sentence-transformers model path for RAG embeddings.
# Use this in restricted networks to avoid HuggingFace download at runtime.
# EMBEDDING_MODEL_PATH=./models/all-MiniLM-L6-v2
# Set DEBUG=1 to include exception details in 500 responses (dev only)
# DEBUG=1
# CORS (comma-separated; no wildcard in production)
CORS_ORIGINS=http://localhost:3000
